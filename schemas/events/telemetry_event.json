{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "francis/schemas/events/telemetry_event.json",
  "title": "TelemetryEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "ts",
    "ingested_at",
    "run_id",
    "kind",
    "stream",
    "source",
    "severity",
    "text",
    "fields"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "const": "telemetry.event"
    },
    "stream": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warn",
        "error",
        "critical"
      ]
    },
    "text": {
      "type": "string"
    },
    "fields": {
      "type": "object"
    }
  }
}
