{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "francis.schemas.events.agent_message",
  "title": "Francis Inter-Unit Message Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "ts",
    "from",
    "to",
    "kind",
    "run_id",
    "trace_id",
    "risk_tier",
    "scope",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "risk_tier": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "payload": {
      "type": "object"
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    }
  }
}
