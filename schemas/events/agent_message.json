{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "francis.schemas.events.agent_message",
  "title": "Francis Agent Message Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_id",
    "ts",
    "from",
    "to",
    "role",
    "kind",
    "run_id",
    "trace_id",
    "payload",
    "risk_tier"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "risk_tier": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "idempotency_key": {
      "type": "string"
    }
  }
}
