{
  "name": "francis-overlay-shell",
  "version": "0.1.0",
  "private": true,
  "author": "Ap3pp3rs94",
  "description": "Electron desktop overlay shell for the Francis HUD",
  "main": "electron/main.js",
  "scripts": {
    "overlay:start": "electron .",
    "overlay:dev": "powershell -ExecutionPolicy Bypass -File electron/dev-run.ps1",
    "overlay:test": "node --test electron/preferences.test.cjs electron/session-state.test.cjs electron/python-runtime.test.cjs electron/hud-runtime.test.cjs",
    "overlay:prepare-runtime": "node electron/prepare-python-runtime.cjs",
    "overlay:pack": "npm run overlay:prepare-runtime && electron-builder --dir --win",
    "overlay:dist": "npm run overlay:prepare-runtime && electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.francis.overlay",
    "productName": "Francis Overlay",
    "asar": true,
    "directories": {
      "output": "dist/overlay",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/python-runtime-staging",
        "to": "python-runtime"
      },
      {
        "from": "apps",
        "to": "python-src/apps",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "services",
        "to": "python-src/services",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "packages",
        "to": "python-src/packages",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis",
        "to": "python-src/francis",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_brain",
        "to": "python-src/francis_brain",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_connectors",
        "to": "python-src/francis_connectors",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_core",
        "to": "python-src/francis_core",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_forge",
        "to": "python-src/francis_forge",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_llm",
        "to": "python-src/francis_llm",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_policy",
        "to": "python-src/francis_policy",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_presence",
        "to": "python-src/francis_presence",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "francis_skills",
        "to": "python-src/francis_skills",
        "filter": [
          "**/*",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "_francis_package_shim.py",
        "to": "python-src/_francis_package_shim.py"
      },
      {
        "from": "pyproject.toml",
        "to": "python-src/pyproject.toml"
      }
    ],
    "win": {
      "icon": "electron/assets/francis-overlay.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Francis-Overlay-${version}-${arch}.${ext}"
    }
  }
}
